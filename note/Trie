#### 类实现前缀树

```cpp
#include <bits/stdc++.h>
using namespace std;

using ll = long long;

class Trie
{
    private:
        struct Node
        {
            Node* child[26];
            int pass;
            int end;
            Node()
            {

                pass=0;
                end=0;
                for(int i=0;i<26;++i) child[i]=nullptr;
            }
        };
        Node* root;
    public:
        Trie()
        {
            root=new Node();
        }
        void insert(string word)
        {
            Node* cur=root;
            cur->pass++;
            for(char c:word)
            {
                int idx=c-'a';
                if(cur->child[idx]==nullptr) cur->child[idx]=new Node();
                cur=cur->child[idx];
                cur->pass++;
            }
            cur->end++;
        }
        int countWords(string word)
        {
            Node* cur=root;
            for(char c:word)
            {
                int idx=c-'a';
                if(cur->child[idx]==nullptr) return 0;
                cur=cur->child[idx];
            }
            return cur->end;
        }
        int countWordsStarting(string word)
        {
            Node* cur=root;
            for(char c:word)
            {
                int idx=c-'a';
                if(cur->child[idx]==nullptr) return 0;
                cur=cur->child[idx];
            }
            return cur->pass;
        }
};

void solve() {
    Trie trie;
    trie.insert("apple");
    trie.insert("apple");
    trie.insert("app");
    cout<<trie.countWords("apple")<<"\n";
    cout<<trie.countWordsStarting("app")<<"\n";
    cout<<trie.countWordsStarting("bpp")<<"\n";
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int T = 1;
    // cin >> T;

    while (T--) {
        solve();
    }

    return 0;
}
